<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Japhet Sunday – Frontend Developer CV</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;0,700;1,300;1,400&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>
<style>
  /* ── Reset & base ── */
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --gold:       #C9A84C;
    --gold-light: #E2C97E;
    --gold-dim:   #8a6e2f;
    --ink:        #0D0D0D;
    --ink-soft:   #1a1a1a;
    --ivory:      #FAFAF7;
    --silver:     #9a9a9a;
    --rule:       #2a2a2a;
  }

  body {
    font-family: 'DM Sans', sans-serif;
    background: #e8e5de;
    display: flex;
    flex-direction: column;
    align-items: center;
    min-height: 100vh;
    padding: 36px 16px 60px;
  }

  /* ── Download button ── */
  .dl-bar {
    width: 100%;
    max-width: 900px;
    display: flex;
    justify-content: flex-end;
    margin-bottom: 18px;
  }

  .dl-btn {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background: var(--ink);
    color: var(--gold);
    border: 1.5px solid var(--gold-dim);
    font-family: 'DM Sans', sans-serif;
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 12px 28px;
    cursor: pointer;
    transition: all .25s;
  }
  .dl-btn:hover {
    background: var(--gold);
    color: var(--ink);
    border-color: var(--gold);
  }
  .dl-btn svg { width: 16px; height: 16px; flex-shrink: 0; }

  /* ── CV shell ── */
  #cv {
    width: 900px;
    min-height: 1272px; /* A4-ish at 96dpi */
    display: grid;
    grid-template-columns: 280px 1fr;
    background: var(--ivory);
    box-shadow: 0 32px 80px rgba(0,0,0,.35), 0 4px 16px rgba(0,0,0,.2);
  }

  /* ════════════════════ LEFT SIDEBAR ════════════════════ */
  .sidebar {
    background: var(--ink);
    padding: 52px 32px 52px 36px;
    display: flex;
    flex-direction: column;
    gap: 0;
    position: relative;
    overflow: hidden;
  }

  /* Gold corner accent */
  .sidebar::before {
    content: '';
    position: absolute;
    top: 0; left: 0;
    width: 100%; height: 4px;
    background: linear-gradient(90deg, var(--gold) 0%, var(--gold-light) 50%, var(--gold-dim) 100%);
  }

  /* Subtle geometric watermark */
  .sidebar::after {
    content: 'JS';
    position: absolute;
    bottom: -20px; right: -10px;
    font-family: 'Cormorant Garamond', serif;
    font-size: 220px;
    font-weight: 700;
    color: rgba(255,255,255,0.025);
    line-height: 1;
    pointer-events: none;
    user-select: none;
  }

  /* ── Avatar / monogram ── */
  .avatar {
    width: 84px;
    height: 84px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--gold-dim), var(--gold-light));
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 28px;
    font-family: 'Cormorant Garamond', serif;
    font-size: 34px;
    font-weight: 700;
    color: var(--ink);
    letter-spacing: -1px;
    box-shadow: 0 0 0 3px rgba(201,168,76,0.25);
    flex-shrink: 0;
  }

  /* ── Name block ── */
  .s-name {
    font-family: 'Cormorant Garamond', serif;
    font-size: 30px;
    font-weight: 600;
    color: #fff;
    line-height: 1.1;
    margin-bottom: 6px;
    letter-spacing: 0.01em;
  }
  .s-title {
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 32px;
  }

  /* ── Gold rule ── */
  .gold-rule {
    width: 40px;
    height: 2px;
    background: linear-gradient(90deg, var(--gold), transparent);
    margin-bottom: 24px;
  }

  /* ── Sidebar section label ── */
  .s-label {
    font-size: 9px;
    font-weight: 600;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--gold-dim);
    margin-bottom: 14px;
    margin-top: 8px;
  }

  /* ── Contact items ── */
  .contact-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 10px;
    margin-bottom: 36px;
  }
  .contact-list li {
    display: flex;
    align-items: flex-start;
    gap: 10px;
  }
  .contact-list .icon {
    width: 14px;
    height: 14px;
    flex-shrink: 0;
    margin-top: 1px;
    opacity: .7;
  }
  .contact-list a,
  .contact-list span {
    font-size: 11.5px;
    color: #c8c8c8;
    text-decoration: none;
    line-height: 1.4;
    word-break: break-all;
  }
  .contact-list a:hover { color: var(--gold-light); }

  /* ── Sidebar divider ── */
  .s-div {
    width: 100%;
    height: 1px;
    background: var(--rule);
    margin: 20px 0;
  }

  /* ── Skills ── */
  .skill-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 8px;
    margin-bottom: 36px;
  }
  .skill-list li {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .skill-name {
    font-size: 11px;
    color: #d4d4d4;
    font-weight: 400;
    letter-spacing: 0.04em;
  }
  .skill-bar {
    height: 2px;
    background: var(--rule);
    border-radius: 2px;
    overflow: hidden;
  }
  .skill-bar-fill {
    height: 100%;
    background: linear-gradient(90deg, var(--gold-dim), var(--gold-light));
    border-radius: 2px;
  }

  /* ── Education / training sidebar blocks ── */
  .s-block {
    margin-bottom: 18px;
  }
  .s-block-title {
    font-size: 12px;
    font-weight: 500;
    color: #e0e0e0;
    margin-bottom: 2px;
    line-height: 1.3;
  }
  .s-block-sub {
    font-size: 11px;
    color: var(--silver);
    line-height: 1.4;
  }
  .s-block-year {
    font-size: 10px;
    color: var(--gold-dim);
    font-weight: 500;
    margin-top: 2px;
    letter-spacing: 0.06em;
  }

  /* ════════════════════ MAIN CONTENT ════════════════════ */
  .main {
    background: var(--ivory);
    padding: 52px 44px 52px 44px;
    display: flex;
    flex-direction: column;
    gap: 0;
    position: relative;
  }

  /* Gold top stripe */
  .main::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 4px;
    background: linear-gradient(90deg, var(--gold-dim) 0%, var(--gold-light) 50%, var(--gold) 100%);
  }

  /* ── Section heading ── */
  .section {
    margin-bottom: 30px;
  }
  .section-head {
    display: flex;
    align-items: center;
    gap: 14px;
    margin-bottom: 16px;
  }
  .section-head h2 {
    font-family: 'Cormorant Garamond', serif;
    font-size: 20px;
    font-weight: 600;
    color: var(--ink);
    letter-spacing: 0.02em;
    white-space: nowrap;
  }
  .section-line {
    flex: 1;
    height: 1px;
    background: linear-gradient(90deg, #d0cec8, transparent);
  }
  .section-dot {
    width: 6px;
    height: 6px;
    background: var(--gold);
    border-radius: 50%;
    flex-shrink: 0;
  }

  /* ── Summary ── */
  .summary-text {
    font-size: 13px;
    line-height: 1.8;
    color: #3a3a3a;
    font-weight: 300;
    border-left: 2px solid var(--gold);
    padding-left: 16px;
    font-style: italic;
    font-family: 'Cormorant Garamond', serif;
    font-size: 16px;
  }

  /* ── Projects ── */
  .project-grid {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }
  .project-card {
    background: #fff;
    border: 1px solid #eae8e2;
    border-left: 3px solid var(--gold);
    padding: 14px 16px;
    position: relative;
  }
  .project-card-head {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 8px;
    margin-bottom: 5px;
  }
  .project-name {
    font-size: 13.5px;
    font-weight: 600;
    color: var(--ink);
    letter-spacing: 0.01em;
  }
  .project-num {
    font-family: 'Cormorant Garamond', serif;
    font-size: 22px;
    font-weight: 300;
    color: #ddd;
    line-height: 1;
    flex-shrink: 0;
  }
  .project-desc {
    font-size: 12px;
    color: #555;
    line-height: 1.6;
    margin-bottom: 6px;
  }
  .project-links {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }
  .project-links a {
    font-size: 10.5px;
    color: var(--gold-dim);
    text-decoration: none;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    border-bottom: 1px solid transparent;
    transition: border-color .2s;
  }
  .project-links a:hover { border-color: var(--gold); }

  /* ── Experience ── */
  .exp-item {
    margin-bottom: 16px;
  }
  .exp-head {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 4px;
  }
  .exp-role {
    font-size: 13.5px;
    font-weight: 600;
    color: var(--ink);
  }
  .exp-date {
    font-size: 10.5px;
    color: var(--gold-dim);
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    white-space: nowrap;
  }
  .exp-company {
    font-size: 11.5px;
    color: var(--silver);
    margin-bottom: 7px;
    font-style: italic;
  }
  .exp-bullets {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .exp-bullets li {
    font-size: 12px;
    color: #444;
    padding-left: 14px;
    position: relative;
    line-height: 1.5;
  }
  .exp-bullets li::before {
    content: '▸';
    position: absolute;
    left: 0;
    color: var(--gold);
    font-size: 9px;
    top: 3px;
  }

  /* ── Certification badge ── */
  .cert-badge {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background: var(--ink);
    color: var(--gold-light);
    padding: 10px 18px;
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.08em;
  }
  .cert-badge .cert-icon {
    font-size: 18px;
  }

  /* ── Footer strip ── */
  .cv-footer {
    margin-top: auto;
    padding-top: 28px;
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .cv-footer-line {
    flex: 1;
    height: 1px;
    background: #e0ddd5;
  }
  .cv-footer-text {
    font-size: 9px;
    color: #bbb;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  /* ════════════════════ PRINT / PDF ════════════════════ */
  @media print {
    body { background: none; padding: 0; }
    .dl-bar { display: none; }
    #cv {
      box-shadow: none;
      width: 100%;
      min-height: 0;
    }
  }

  @page {
    size: A4;
    margin: 0;
  }
</style>
</head>
<body>

<!-- Download bar -->
<div class="dl-bar">
  <button class="dl-btn" onclick="downloadPDF()">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
      <polyline points="7 10 12 15 17 10"/>
      <line x1="12" y1="15" x2="12" y2="3"/>
    </svg>
    Download PDF
  </button>
</div>

<!-- CV -->
<div id="cv">

  <!-- ══ SIDEBAR ══ -->
  <aside class="sidebar">
    <div class="avatar">JS</div>

    <div class="s-name">Japhet<br>Sunday</div>
    <div class="s-title">Frontend Developer</div>
    <div class="gold-rule"></div>

    <!-- Contact -->
    <div class="s-label">Contact</div>
    <ul class="contact-list">
      <li>
        <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="#C9A84C" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
        <a href="mailto:japhet996sunday@gmail.com">japhet996sunday@gmail.com</a>
      </li>
      <li>
        <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="#C9A84C" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.61 3.32C1.6 2.18 2.44 1.18 3.58 1h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.56a16 16 0 0 0 6 6l.92-.92a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
        <span>09070065083<br>08057199024</span>
      </li>
      <li>
        <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="#C9A84C" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
        <span>Abuja, Nigeria</span>
      </li>
      <li>
        <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="#C9A84C" stroke-width="2"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/></svg>
        <a href="https://github.com/japhet996sunday-cell" target="_blank">github.com/japhet996sunday-cell</a>
      </li>
    </ul>

    <div class="s-div"></div>

    <!-- Skills -->
    <div class="s-label">Skills</div>
    <ul class="skill-list">
      <li><span class="skill-name">HTML5</span><div class="skill-bar"><div class="skill-bar-fill" style="width:95%"></div></div></li>
      <li><span class="skill-name">CSS3</span><div class="skill-bar"><div class="skill-bar-fill" style="width:92%"></div></div></li>
      <li><span class="skill-name">JavaScript (ES6)</span><div class="skill-bar"><div class="skill-bar-fill" style="width:80%"></div></div></li>
      <li><span class="skill-name">Responsive Design</span><div class="skill-bar"><div class="skill-bar-fill" style="width:88%"></div></div></li>
      <li><span class="skill-name">API Integration</span><div class="skill-bar"><div class="skill-bar-fill" style="width:78%"></div></div></li>
      <li><span class="skill-name">Git & GitHub</span><div class="skill-bar"><div class="skill-bar-fill" style="width:82%"></div></div></li>
      <li><span class="skill-name">localStorage / JSON</span><div class="skill-bar"><div class="skill-bar-fill" style="width:85%"></div></div></li>
      <li><span class="skill-name">Debugging</span><div class="skill-bar"><div class="skill-bar-fill" style="width:80%"></div></div></li>
      <li><span class="skill-name">VS Code</span><div class="skill-bar"><div class="skill-bar-fill" style="width:90%"></div></div></li>
    </ul>

    <div class="s-div"></div>

    <!-- Education -->
    <div class="s-label">Education</div>
    <div class="s-block">
      <div class="s-block-title">HND Mass Communication</div>
      <div class="s-block-sub">Lens Polytechnic</div>
      <div class="s-block-year">2023</div>
    </div>

    <div class="s-div"></div>

    <!-- Training -->
    <div class="s-label">Training</div>
    <div class="s-block">
      <div class="s-block-title">Web Development Certificate</div>
      <div class="s-block-sub">Darl Creative Hub Academy</div>
      <div class="s-block-year">Mar 2026 – Jul 2026</div>
    </div>

  </aside>

  <!-- ══ MAIN ══ -->
  <main class="main">

    <!-- Summary -->
    <section class="section">
      <div class="section-head">
        <div class="section-dot"></div>
        <h2>Profile</h2>
        <div class="section-line"></div>
      </div>
      <p class="summary-text">
        Frontend Developer skilled in HTML, CSS, JavaScript, responsive design, API integration, and modern web applications. Experienced building interactive projects including dashboards, AI chat apps, and calculators. Passionate about creating clean, user-friendly interfaces and seeking junior developer or internship opportunities.
      </p>
    </section>

    <!-- Projects -->
    <section class="section">
      <div class="section-head">
        <div class="section-dot"></div>
        <h2>Projects</h2>
        <div class="section-line"></div>
      </div>
      <div class="project-grid">

        <div class="project-card">
          <div class="project-card-head">
            <div class="project-name">Smart Study Dashboard</div>
            <div class="project-num">01</div>
          </div>
          <p class="project-desc">Pomodoro timer, task manager, notes module, weather API integration, and dark mode — a full productivity suite built in-browser.</p>
          <div class="project-links">
            <a href="https://smartstudy-dashboard.netlify.app/" target="_blank">↗ Live Demo</a>
            <a href="https://github.com/japhet996sunday-cell/smartstudy-dashboard" target="_blank">⌥ GitHub</a>
          </div>
        </div>

        <div class="project-card">
          <div class="project-card-head">
            <div class="project-name">NovaChatAI</div>
            <div class="project-num">02</div>
          </div>
          <p class="project-desc">AI-powered chat application using OpenRouter API (Mistral 7B). Features real-time AI responses, localStorage persistence, dark/light theme, collapsible sidebar, and Markdown rendering.</p>
          <div class="project-links">
            <a href="https://novachat-live.netlify.app/" target="_blank">↗ Live Demo</a>
          </div>
        </div>

        <div class="project-card">
          <div class="project-card-head">
            <div class="project-name">Scientific Calculator</div>
            <div class="project-num">03</div>
          </div>
          <p class="project-desc">Mobile-first scientific calculator with trigonometric functions, operator precedence, and responsive touch layout.</p>
          <div class="project-links">
            <a href="https://japhet996sunday-cell.github.io/phone-scientific-calculator-/" target="_blank">↗ Live Demo</a>
          </div>
        </div>

      </div>
    </section>

    <!-- Experience -->
    <section class="section">
      <div class="section-head">
        <div class="section-dot"></div>
        <h2>Experience</h2>
        <div class="section-line"></div>
      </div>
      <div class="exp-item">
        <div class="exp-head">
          <div class="exp-role">HTML & CSS Tutor</div>
          <div class="exp-date">May 2026 – Present</div>
        </div>
        <div class="exp-company">Independent / Freelance</div>
        <ul class="exp-bullets">
          <li>Teach HTML & CSS fundamentals to beginners in structured sessions</li>
          <li>Guide students through responsive design principles and best practices</li>
          <li>Mentor students to build and deploy real-world portfolio projects</li>
        </ul>
      </div>
    </section>

    <!-- Certification -->
    <section class="section">
      <div class="section-head">
        <div class="section-dot"></div>
        <h2>Certification</h2>
        <div class="section-line"></div>
      </div>
      <div class="cert-badge">
        <span class="cert-icon">✦</span>
        DCH Web Development Certificate &nbsp;·&nbsp; 2026
      </div>
    </section>

    <!-- Footer -->
    <div class="cv-footer">
      <div class="cv-footer-line"></div>
      <div class="cv-footer-text">Japhet Sunday &nbsp;·&nbsp; Frontend Developer &nbsp;·&nbsp; 2026</div>
      <div class="cv-footer-line"></div>
    </div>

  </main>
</div>

<script>
function downloadPDF() {
  const btn = document.querySelector('.dl-btn');
  btn.textContent = 'Generating…';
  btn.disabled = true;

  const element = document.getElementById('cv');

  const opt = {
    margin:      0,
    filename:    'Japhet_Sunday_CV.pdf',
    image:       { type: 'jpeg', quality: 0.98 },
    html2canvas: {
      scale: 2,
      useCORS: true,
      letterRendering: true,
      backgroundColor: '#FAFAF7'
    },
    jsPDF: {
      unit: 'mm',
      format: 'a4',
      orientation: 'portrait'
    }
  };

  html2pdf().set(opt).from(element).save().then(() => {
    btn.innerHTML = `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:16px;height:16px"><polyline points="20 6 9 17 4 12"/></svg> Downloaded`;
    setTimeout(() => {
      btn.innerHTML = `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:16px;height:16px"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg> Download PDF`;
      btn.disabled = false;
    }, 2500);
  });
}
</script>
</body>
</html>
